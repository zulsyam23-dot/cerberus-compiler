program typecheck_env_mod;
function tc_env_new(): map;
begin
  return map_new();
end;
function tc_env_define(env: map; name: string; ty: string): map;
begin
  return map_set(env, name, ty);
end;
function tc_env_has(env: map; name: string): boolean;
begin
  return map_has(env, name);
end;
function tc_env_get(env: map; name: string): string;
begin
  if map_has(env, name) then
    return map_get(env, name);
  return '';
end;
begin
end.
