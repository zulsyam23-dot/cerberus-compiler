program typecheck_util;

function tc_is_space(ch: string): boolean;
begin
  return ch = ' ' or ch = '\t' or ch = '\n' or ch = '\r';
end;

function tc_trim(s: string): string;
var i: integer;
j: integer;
n: integer;
done: boolean;
begin
  n := strlen(s);
  if n = 0 then
    return '';
  i := 0;
  done := false;
  while i < n and not done do
  begin
    if tc_is_space(substr(s, i, 1)) then
      i := i + 1
    else
      done := true;
  end;
  j := n - 1;
  done := false;
  while j >= i and not done do
  begin
    if tc_is_space(substr(s, j, 1)) then
      j := j - 1
    else
      done := true;
  end;
  if j < i then
    return '';
  return substr(s, i, j - i + 1);
end;

function tc_kind(node: string): string;
var i: integer;
n: integer;
ch: string;
begin
  n := strlen(node);
  i := 0;
  while i < n do
  begin
    ch := substr(node, i, 1);
    if ch = '{' or ch = '[' then
      return substr(node, 0, i);
    i := i + 1;
  end;
  return node;
end;

function tc_extract(node: string): string;
var n: integer;
 i: integer;
 start: integer;
 end_idx: integer;
 ch: string;
begin
  n := strlen(node);
  if n < 3 then
    return '';
  i := 0;
  start := -1;
  end_idx := -1;
  while i < n do
  begin
    ch := substr(node, i, 1);
    if start < 0 and ch = '{' then
      start := i;
    if ch = '}' then
      end_idx := i;
    i := i + 1;
  end;
  if start < 0 or end_idx <= start then
    return '';
  return substr(node, start + 1, end_idx - start - 1);
end;

function tc_split_top(s: string; sep: string): vector of string;
var out: vector of string;
cur: string;
n: integer;
i: integer;
ch: string;
depth: integer;
in_str: boolean;
next: string;
begin
  if tc_trim(s) = '' then
    return vector_new_str();
  out := vector_new_str();
  cur := '';
  n := strlen(s);
  i := 0;
  depth := 0;
  in_str := false;
  while i < n do
  begin
    ch := substr(s, i, 1);
    if in_str then
    begin
      if ch = '''' then
      begin
        if i + 1 < n and substr(s, i + 1, 1) = '''' then
        begin
          cur := concat(cur, '''');
          cur := concat(cur, '''');
          if i + 2 >= n then
            in_str := false
          else
          begin
            next := substr(s, i + 2, 1);
            if next = '}' or next = ']' or next = ',' or next = ';' or next = ')' then
              in_str := false;
          end;
          i := i + 2;
        end
        else
        begin
          in_str := false;
          cur := concat(cur, ch);
          i := i + 1;
        end;
      end
      else
      begin
        cur := concat(cur, ch);
        i := i + 1;
      end;
    end
    else if ch = '''' then
    begin
      in_str := true;
      cur := concat(cur, ch);
      i := i + 1;
    end
    else if ch = '{' then
    begin
      depth := depth + 1;
      cur := concat(cur, ch);
      i := i + 1;
    end
    else if ch = '}' then
    begin
      depth := depth - 1;
      cur := concat(cur, ch);
      i := i + 1;
    end
    else if depth = 0 and ch = sep then
    begin
      out := vector_push(out, tc_trim(cur));
      cur := '';
      i := i + 1;
    end
    else
    begin
      cur := concat(cur, ch);
      i := i + 1;
    end;
  end;
  out := vector_push(out, tc_trim(cur));
  return out;
end;

function tc_extract_list(node: string): vector of string;
var n: integer;
body: string;
begin
  n := strlen(node);
  if n < 3 then
    return vector_new_str();
  body := substr(node, 2, n - 3);
  return tc_split_top(body, ',');
end;

begin
end.

