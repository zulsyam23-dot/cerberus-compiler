program typecheck_stmt;
uses typecheck_core, typecheck_util, typecheck_types, typecheck_expr, builtins;

function tc_stmt_block(state: map; block: string): map;
var body: string;
parts: vector of string;
stmts: vector of string;
i: integer;
n: integer;
begin
  body := tc_extract(block);
  parts := tc_split_top(body, ';');
  if vector_len(parts) = 0 then
    return state;
  if vector_len(parts) >= 2 then
    stmts := tc_extract_list(vector_get(parts, 1))
  else
    stmts := tc_extract_list(vector_get(parts, 0));
  i := 0;
  n := vector_len(stmts);
  while i < n do
  begin
    if tc_has_error(state) then
      return state;
    state := tc_stmt(state, vector_get(stmts, i));
    i := i + 1;
  end;
  return state;
end;

function tc_stmt(state: map; stmt: string): map;
var kind: string;
body: string;
parts: vector of string;
name: string;
expr: string;
t: string;
args: vector of string;
cond: string;
then_s: string;
else_s: string;
params: vector of string;
sig: string;
ret: string;
i: integer;
n: integer;
begin
  if tc_has_error(state) then
    return state;
  kind := tc_kind(stmt);
  if kind = 'SReturn' then
  begin
    body := tc_extract(stmt);
    if tc_get_ret(state) = '' then
      return tc_set_error(state, 'return outside function');
    if body = '' then
    begin
      if tc_get_ret(state) <> 'void' then
        return tc_set_error(state, 'return expects value');
      return state;
    end;
    state := tc_expr_type(state, body);
    if tc_get_result(state) <> tc_get_ret(state) then
      return tc_set_error(state, 'return type mismatch');
    return state;
  end;
  if kind = 'SEmpty' then
    return state;
  if kind = 'SBlock' then
  begin
    body := tc_extract(stmt);
    return tc_stmt_block(state, body);
  end;
  if kind = 'SAssign' then
  begin
    body := tc_extract(stmt);
    parts := tc_split_top(body, ';');
    name := vector_get(parts, 0);
    expr := vector_get(parts, 1);
    state := tc_expr_type(state, expr);
    t := tc_get_result(state);
    if map_has(state, name) then
    begin
      if map_get(state, name) <> t then
        state := tc_set_error(
          state,
          concat(
            'assignment type mismatch for ',
            concat(name, concat(': expected ', concat(map_get(state, name), concat(', got ', t))))
          )
        );
    end
    else
      state := map_set(state, name, t);
    return state;
  end;
  if kind = 'SCall' then
  begin
    body := tc_extract(stmt);
    parts := tc_split_top(body, ';');
    name := vector_get(parts, 0);
    args := tc_extract_list(vector_get(parts, 1));
    if name = 'writeln' then
    begin
      if vector_len(args) <> 1 then state := tc_set_error(state, 'writeln expects 1 arg');
      state := tc_expr_type(state, vector_get(args, 0));
      t := tc_get_result(state);
      if t <> 'int' and t <> 'bool' and t <> 'string' then
        state := tc_set_error(state, 'writeln expects int/bool/string');
      return state;
    end;
    if name = 'writefile' then
    begin
      if vector_len(args) <> 2 then state := tc_set_error(state, 'writefile expects 2 args');
      state := tc_expr_type(state, vector_get(args, 0));
      if tc_get_result(state) <> 'string' then state := tc_set_error(state, 'writefile path must be string');
      state := tc_expr_type(state, vector_get(args, 1));
      if tc_get_result(state) <> 'string' then state := tc_set_error(state, 'writefile content must be string');
      return state;
    end;
    if name = 'sleep_ms' then
    begin
      if vector_len(args) <> 1 then state := tc_set_error(state, 'sleep_ms expects 1 arg');
      state := tc_expr_type(state, vector_get(args, 0));
      if tc_get_result(state) <> 'int' then state := tc_set_error(state, 'sleep_ms expects int');
      return state;
    end;
    if name = 'log_str' then
    begin
      if vector_len(args) <> 1 then state := tc_set_error(state, 'log_str expects 1 arg');
      state := tc_expr_type(state, vector_get(args, 0));
      if tc_get_result(state) <> 'string' then state := tc_set_error(state, 'log_str expects string');
      return state;
    end;
    if name = 'log_int' then
    begin
      if vector_len(args) <> 1 then state := tc_set_error(state, 'log_int expects 1 arg');
      state := tc_expr_type(state, vector_get(args, 0));
      if tc_get_result(state) <> 'int' then state := tc_set_error(state, 'log_int expects int');
      return state;
    end;
    if name = 'log_bool' then
    begin
      if vector_len(args) <> 1 then state := tc_set_error(state, 'log_bool expects 1 arg');
      state := tc_expr_type(state, vector_get(args, 0));
      if tc_get_result(state) <> 'bool' then state := tc_set_error(state, 'log_bool expects bool');
      return state;
    end;
    if name = 'builder_new' then
    begin
      if vector_len(args) <> 1 then state := tc_set_error(state, 'builder_new expects 1 arg');
      if vector_len(args) > 0 then
      begin
        state := tc_expr_type(state, vector_get(args, 0));
        if tc_get_result(state) <> 'string' then state := tc_set_error(state, 'builder_new expects string');
      end;
      return state;
    end;
    if name = 'builder_main' then
    begin
      if vector_len(args) <> 0 then state := tc_set_error(state, 'builder_main expects 0 args');
      return state;
    end;
    if name = 'builder_write' then
    begin
      if vector_len(args) <> 1 then state := tc_set_error(state, 'builder_write expects 1 arg');
      if vector_len(args) > 0 then
      begin
        state := tc_expr_type(state, vector_get(args, 0));
        if tc_get_result(state) <> 'string' then state := tc_set_error(state, 'builder_write expects string');
      end;
      return state;
    end;
    if name = 'builder_func_begin' then
    begin
      if vector_len(args) <> 2 then state := tc_set_error(state, 'builder_func_begin expects 2 args');
      if vector_len(args) > 0 then
      begin
        state := tc_expr_type(state, vector_get(args, 0));
        if tc_get_result(state) <> 'string' then state := tc_set_error(state, 'builder_func_begin name must be string');
      end;
      if vector_len(args) > 1 then
      begin
        state := tc_expr_type(state, vector_get(args, 1));
        if tc_get_result(state) <> 'int' then state := tc_set_error(state, 'builder_func_begin param count must be int');
      end;
      return state;
    end;
    if name = 'builder_func_end' then
    begin
      if vector_len(args) <> 0 then state := tc_set_error(state, 'builder_func_end expects 0 args');
      return state;
    end;
    if name = 'builder_emit_halt' then
    begin
      if vector_len(args) <> 0 then state := tc_set_error(state, 'builder_emit_halt expects 0 args');
      return state;
    end;
    if name = 'builder_label' then
    begin
      if vector_len(args) <> 1 then state := tc_set_error(state, 'builder_label expects 1 arg');
      if vector_len(args) > 0 then
      begin
        state := tc_expr_type(state, vector_get(args, 0));
        if tc_get_result(state) <> 'int' then state := tc_set_error(state, 'builder_label expects int');
      end;
      return state;
    end;
    if name = 'builder_jump' then
    begin
      if vector_len(args) <> 1 then state := tc_set_error(state, 'builder_jump expects 1 arg');
      if vector_len(args) > 0 then
      begin
        state := tc_expr_type(state, vector_get(args, 0));
        if tc_get_result(state) <> 'int' then state := tc_set_error(state, 'builder_jump expects int');
      end;
      return state;
    end;
    if name = 'builder_jump_if_false' then
    begin
      if vector_len(args) <> 1 then state := tc_set_error(state, 'builder_jump_if_false expects 1 arg');
      if vector_len(args) > 0 then
      begin
        state := tc_expr_type(state, vector_get(args, 0));
        if tc_get_result(state) <> 'int' then state := tc_set_error(state, 'builder_jump_if_false expects int');
      end;
      return state;
    end;
    if name = 'emit_bcop_new' or
       name = 'emit_bcop_main' or
       name = 'emit_bcop_write' or
       name = 'emit_bcop_func_begin' or
       name = 'emit_bcop_func_end' or
       name = 'emit_bcop_halt' or
       name = 'emit_bcop_label' or
       name = 'emit_bcop_jump' or
       name = 'emit_bcop_jump_if_false' then
    begin
      if vector_len(args) <> 0 then
        state := tc_set_error(state, concat(name, ' expects 0 args'));
      return state;
    end;
    if strlen(name) >= 3 and substr(name, 0, 3) = 'bc_' then
      return state;
    if map_has(state, tc_fn_key(name)) then
    begin
      sig := map_get(state, tc_fn_key(name));
      parts := tc_split_top(sig, '|');
      ret := vector_get(parts, 0);
      params := tc_split_top(vector_get(parts, 1), ';');
      if vector_len(params) <> vector_len(args) then
        return tc_set_error(state, concat('invalid arg count for ', name));
      i := 0;
      n := vector_len(args);
      while i < n do
      begin
        state := tc_expr_type(state, vector_get(args, i));
        if tc_get_result(state) <> vector_get(params, i) then
          state := tc_set_error(state, concat('arg type mismatch for ', name));
        i := i + 1;
      end;
      if ret <> 'void' then
        return tc_set_error(state, concat('function used as procedure: ', name));
      return state;
    end;
    if tc_builtin_is_known(name) then
      return tc_set_error(state, concat('builtin not yet supported in selfhost statement codegen: ', name));
    state := tc_set_error(state, concat('unknown procedure ', name));
    return state;
  end;
  if kind = 'SIf' then
  begin
    body := tc_extract(stmt);
    parts := tc_split_top(body, ';');
    cond := vector_get(parts, 0);
    then_s := vector_get(parts, 1);
    else_s := vector_get(parts, 2);
    state := tc_expr_type(state, cond);
    if tc_get_result(state) <> 'bool' then state := tc_set_error(state, 'if expects bool condition');
    state := tc_stmt(state, then_s);
    state := tc_stmt(state, else_s);
    return state;
  end;
  if kind = 'SWhile' then
  begin
    body := tc_extract(stmt);
    parts := tc_split_top(body, ';');
    cond := vector_get(parts, 0);
    expr := vector_get(parts, 1);
    state := tc_expr_type(state, cond);
    if tc_get_result(state) <> 'bool' then state := tc_set_error(state, 'while expects bool condition');
    state := tc_stmt(state, expr);
    return state;
  end;
  state := tc_set_error(state, 'unknown statement');
  return state;
end;

begin
end.

