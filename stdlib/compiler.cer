program compiler;
uses lexer, parser, typecheck, codegen, ast, vm;

var src_path, out_path, src, ast, err: string;
no_tc: boolean;
package_mode: boolean;
arg0: string;
arg_idx: integer;
pkg_entry: string;
pkg_limit_steps: string;
pkg_limit_stack: string;
pkg_limit_call: string;
pkg_idx: integer;
pkg_opt: string;
parse_opts: boolean;

function starts_with(s: string; prefix: string): boolean;
begin
  if strlen(s) < strlen(prefix) then
    return false;
  return substr(s, 0, strlen(prefix)) = prefix;
end;

function c_target_root(): string;
var root: string;
begin
  root := '.cerberus_target';
  if env_has('CERBERUS_TARGET_DIR') then
  begin
    if env_get('CERBERUS_TARGET_DIR') <> '' then
      root := env_get('CERBERUS_TARGET_DIR');
  end;
  return root;
end;

function c_extract(node: string): string;
var n: integer;
 i: integer;
 start: integer;
 end_idx: integer;
 ch: string;
begin
  n := strlen(node);
  if n < 3 then
    return '';
  i := 0;
  start := -1;
  end_idx := -1;
  while i < n do
  begin
    ch := substr(node, i, 1);
    if start < 0 and ch = '{' then
      start := i;
    if ch = '}' then
      end_idx := i;
    i := i + 1;
  end;
  if start < 0 or end_idx <= start then
    return '';
  return substr(node, start + 1, end_idx - start - 1);
end;

function c_split_top(s: string; sep: string): vector of string;
var out: vector of string;
cur: string;
n: integer;
i: integer;
ch: string;
depth: integer;
in_str: boolean;
next: string;
begin
  out := vector_new_str();
  if s = '' then
    return out;
  cur := '';
  n := strlen(s);
  i := 0;
  depth := 0;
  in_str := false;
  while i < n do
  begin
    ch := substr(s, i, 1);
    if in_str then
    begin
      if ch = '''' then
      begin
        if i + 1 < n and substr(s, i + 1, 1) = '''' then
        begin
          cur := concat(cur, '''');
          cur := concat(cur, '''');
          if i + 2 >= n then
            in_str := false
          else
          begin
            next := substr(s, i + 2, 1);
            if next = '}' or next = ']' or next = ',' or next = ';' or next = ')' then
              in_str := false;
          end;
          i := i + 2;
        end
        else
        begin
          in_str := false;
          cur := concat(cur, ch);
          i := i + 1;
        end;
      end
      else
      begin
        cur := concat(cur, ch);
        i := i + 1;
      end;
    end
    else if ch = '''' then
    begin
      in_str := true;
      cur := concat(cur, ch);
      i := i + 1;
    end
    else if ch = '{' then
    begin
      depth := depth + 1;
      cur := concat(cur, ch);
      i := i + 1;
    end
    else if ch = '}' then
    begin
      depth := depth - 1;
      cur := concat(cur, ch);
      i := i + 1;
    end
    else if depth = 0 and ch = sep then
    begin
      out := vector_push(out, cur);
      cur := '';
      i := i + 1;
    end
    else
    begin
      cur := concat(cur, ch);
      i := i + 1;
    end;
  end;
  out := vector_push(out, cur);
  return out;
end;

function c_extract_list(node: string): vector of string;
var n: integer;
body: string;
begin
  n := strlen(node);
  if n < 3 then
    return vector_new_str();
  body := substr(node, 2, n - 3);
  return c_split_top(body, ',');
end;

function c_vec_concat(a: vector of string; b: vector of string): vector of string;
var out: vector of string;
i: integer;
n: integer;
begin
  out := vector_new_str();
  i := 0;
  n := vector_len(a);
  while i < n do
  begin
    out := vector_push(out, vector_get(a, i));
    i := i + 1;
  end;
  i := 0;
  n := vector_len(b);
  while i < n do
  begin
    out := vector_push(out, vector_get(b, i));
    i := i + 1;
  end;
  return out;
end;

function c_contains(hay: string; needle: string): boolean;
var i: integer;
 n: integer;
 m: integer;
begin
  n := strlen(hay);
  m := strlen(needle);
  if m = 0 then
    return true;
  if n < m then
    return false;
  i := 0;
  while i <= n - m do
  begin
    if substr(hay, i, m) = needle then
      return true;
    i := i + 1;
  end;
  return false;
end;

function c_dirname(path: string): string;
var i: integer;
n: integer;
last: integer;
ch: string;
sep: string;
begin
  n := strlen(path);
  last := -1;
  sep := substr(path_join('a', 'b'), 1, 1);
  i := 0;
  while i < n do
  begin
    ch := substr(path, i, 1);
    if ch = '/' or ch = sep then
      last := i;
    i := i + 1;
  end;
  if last < 0 then
    return '.';
  if last = 0 then
    return '/';
  if last = 2 and substr(path, 1, 1) = ':' then
    return substr(path, 0, 3);
  return substr(path, 0, last);
end;

function c_basename(path: string): string;
var i: integer;
n: integer;
last: integer;
ch: string;
sep: string;
begin
  n := strlen(path);
  last := -1;
  sep := substr(path_join('a', 'b'), 1, 1);
  i := 0;
  while i < n do
  begin
    ch := substr(path, i, 1);
    if ch = '/' or ch = sep then
      last := i;
    i := i + 1;
  end;
  if last < 0 then
    return path;
  if last + 1 >= n then
    return '';
  return substr(path, last + 1, n - last - 1);
end;

function c_stem(path: string): string;
var name: string;
i: integer;
n: integer;
last_dot: integer;
ch: string;
begin
  name := c_basename(path);
  n := strlen(name);
  if n = 0 then
    return 'output';
  last_dot := -1;
  i := 0;
  while i < n do
  begin
    ch := substr(name, i, 1);
    if ch = '.' then
      last_dot := i;
    i := i + 1;
  end;
  if last_dot <= 0 then
    return name;
  return substr(name, 0, last_dot);
end;

function c_default_output_for(src: string; is_package: boolean): string;
var root: string;
stem: string;
begin
  root := c_target_root();
  stem := c_stem(src);
  if is_package then
    return path_join(path_join(root, 'package'), concat(stem, '.crt'));
  return path_join(path_join(root, 'debug'), concat(stem, '.cerb'));
end;

procedure c_write_build_meta(kind: string; source_path: string; artifact_path: string);
var root: string;
meta_path: string;
payload: string;
ts: integer;
begin
  root := c_target_root();
  meta_path := path_join(path_join(root, 'meta'), concat(concat(c_stem(source_path), '.'), concat(kind, '.txt')));
  ts := now_timestamp();
  payload := concat('kind=', kind);
  payload := concat(payload, concat(';source=', source_path));
  payload := concat(payload, concat(';artifact=', artifact_path));
  payload := concat(payload, concat(';timestamp=', p_int_to_str(ts)));
  payload := concat(payload, ';toolchain=cerberus_selfhost');
  writefile(meta_path, payload);
end;

