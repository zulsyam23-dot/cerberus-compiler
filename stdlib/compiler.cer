function c_merge_uses(ast_root: string; base_dir: string): string;
var body: string;
parts: vector of string;
name: string;
uses_node: string;
block: string;
mods: vector of string;
decls: vector of string;
stmts: vector of string;
mod_ast: string;
mod_body: string;
  mod_parts: vector of string;
  mod_block: string;
  mod_decls: vector of string;
  merged_mods: vector of string;
  mod_stmts: vector of string;
  i: integer;
  n: integer;
  path: string;
  queue: vector of string;
  visited: string;
  mod_uses: vector of string;
  skip: boolean;
  mod_name: string;
  iter: integer;
  max_iter: integer;
begin
  if starts_with(ast_root, 'ERROR:') then
    return ast_root;
  body := c_extract(ast_root);
  parts := c_split_top(body, ';');
  if vector_len(parts) < 3 then
  begin
    if env_has('CERBERUS_DEBUG_AST') then
    begin
      writeln('DEBUG: parts<3');
      if strlen(body) > 120 then
        writeln(concat('BODY_HEAD: ', substr(body, 0, 120)))
      else
        writeln(concat('BODY_HEAD: ', body));
    end;
    return 'ERROR: invalid ast (merge uses)';
  end;
  name := vector_get(parts, 0);
  uses_node := vector_get(parts, 1);
  block := vector_get(parts, 2);
  mods := c_extract_list(uses_node);
  if env_has('CERBERUS_DEBUG_AST') then
    writeln(concat('USES_NODE: ', uses_node));
  if vector_len(mods) = 0 then
  begin
    if env_has('CERBERUS_DEBUG_AST') then
      writeln('DEBUG: uses empty');
    return ast_root;
  end;
  merged_mods := vector_new_str();
  queue := mods;
  visited := ',';
  iter := 0;
  max_iter := 5000;
  while vector_len(queue) > 0 do
  begin
    iter := iter + 1;
    if env_has('CERBERUS_DEBUG_AST') then
    begin
      if iter = 1 or iter = 10 or iter = 50 or iter = 100 or iter = 200 or iter = 500 or iter = 1000 then
        writeln(concat('MERGE_STEP: ', concat(p_int_to_str(iter), concat(' queue=', p_int_to_str(vector_len(queue))))));
    end;
    if iter > max_iter then
      return 'ERROR: merge uses overflow';
    path := '';
    mod_name := vector_get(queue, 0);
    queue := vector_remove(queue, 0);
    if env_has('CERBERUS_DEBUG_AST') then
      writeln(concat('MERGE: ', mod_name));
    skip := false;
    if c_contains(visited, concat(',', concat(mod_name, ','))) then
      skip := true
    else
    begin
      visited := concat(visited, concat(mod_name, ','));
      path := c_resolve_module(base_dir, mod_name);
    end;
    if not skip then
    begin
      if path = '' then
        return concat('ERROR: module not found: ', mod_name);
      mod_ast := parse_string(readfile(path));
      if starts_with(mod_ast, 'ERROR:') then
        return mod_ast;
      mod_body := c_extract(mod_ast);
      mod_parts := c_split_top(mod_body, ';');
      if vector_len(mod_parts) < 3 then
        return concat('ERROR: invalid module: ', mod_name);
      mod_uses := c_extract_list(vector_get(mod_parts, 1));
      if vector_len(mod_uses) > 0 then
        queue := c_vec_concat(queue, mod_uses);
  mod_block := vector_get(mod_parts, 2);
  mod_parts := c_split_top(c_extract(mod_block), ';');
  if vector_len(mod_parts) < 2 then
  begin
    if env_has('CERBERUS_DEBUG_AST') then
    begin
      writeln(concat('MOD_AST_HEAD: ', substr(mod_ast, 0, 120)));
      writeln(concat('MOD_BLOCK_HEAD: ', substr(mod_block, 0, 120)));
      writeln(concat('MOD_BLOCK_LEN: ', p_int_to_str(strlen(mod_block))));
      if strlen(mod_block) > 120 then
        writeln(concat('MOD_BLOCK_TAIL: ', substr(mod_block, strlen(mod_block) - 120, 120)));
      if c_contains(mod_block, ';') then
        writeln('MOD_BLOCK_HAS_SEMI: true')
      else
        writeln('MOD_BLOCK_HAS_SEMI: false');
    end;
    return concat('ERROR: invalid module block: ', mod_name);
  end;
      mod_decls := c_extract_list(vector_get(mod_parts, 0));
      mod_stmts := c_extract_list(vector_get(mod_parts, 1));
      if vector_len(mod_stmts) > 0 then
        return concat('ERROR: module must not contain statements: ', mod_name);
      merged_mods := c_vec_concat(mod_decls, merged_mods);
    end;
  end;
  mod_parts := c_split_top(c_extract(block), ';');
  if vector_len(mod_parts) < 2 then
    return 'ERROR: invalid program block';
  decls := c_extract_list(vector_get(mod_parts, 0));
  stmts := c_extract_list(vector_get(mod_parts, 1));
  decls := c_vec_concat(merged_mods, decls);
  block := ast_block(decls, stmts);
  return ast_program(name, ast_uses(vector_new_str()), block);
end;

begin
  if env_has('CERBERUS_DEBUG_PROGRESS') then
    writeln('PROGRESS: enter');
  if env_has('CERBERUS_DEBUG_AST') then
    writeln('DEBUG: compiler entry');
  if arg_count() < 1 then
  begin
    writeln('usage: compiler [--no-typecheck|--bootstrap] [--package] <input> [output]');
    writeln('       package opts: [--entry <label>] [--limit-steps <n>] [--limit-stack <n>] [--limit-call <n>]');
    writeln('       default output root: .cerberus_target (or CERBERUS_TARGET_DIR)');
    writeln('   or: compiler no-typecheck <input> [output]');
    writeln('   or: compiler package <vm_script> [output.crt] [package opts]');
    return;
  end;

  no_tc := false;
  package_mode := false;
  arg_idx := 0;
  arg0 := arg(0);
  if env_has('CERBERUS_DEBUG_AST') then
    writeln(concat('DEBUG: arg0=', arg0));
  if arg0 = '--help' or arg0 = '-h' or arg0 = 'help' then
  begin
    writeln('usage: compiler [--no-typecheck|--bootstrap] [--package] <input> [output]');
    writeln('       package opts: [--entry <label>] [--limit-steps <n>] [--limit-stack <n>] [--limit-call <n>]');
    writeln('       default output root: .cerberus_target (or CERBERUS_TARGET_DIR)');
    writeln('   or: compiler no-typecheck <input> [output]');
    writeln('   or: compiler package <vm_script> [output.crt] [package opts]');
    return;
  end;
  parse_opts := true;
  while arg_idx < arg_count() and parse_opts do
  begin
    arg0 := arg(arg_idx);
    if arg0 = 'no-typecheck' or arg0 = '--no-typecheck' or arg0 = '--bootstrap' then
    begin
      no_tc := true;
      arg_idx := arg_idx + 1;
    end
    else if arg0 = 'package' or arg0 = '--package' or arg0 = '--toolchain-package' then
    begin
      package_mode := true;
      arg_idx := arg_idx + 1;
    end
    else
      parse_opts := false;
  end;
  if arg_idx < arg_count() then
  begin
    if starts_with(arg(arg_idx), '--') then
    begin
      writeln(concat('ERROR: unknown option ', arg(arg_idx)));
      writeln('usage: compiler [--no-typecheck|--bootstrap] [--package] <input> [output]');
      writeln('       package opts: [--entry <label>] [--limit-steps <n>] [--limit-stack <n>] [--limit-call <n>]');
      writeln('       default output root: .cerberus_target (or CERBERUS_TARGET_DIR)');
      return;
    end;
  end;

  if arg_count() <= arg_idx then
  begin
    writeln('usage: compiler [--no-typecheck|--bootstrap] [--package] <input> [output]');
    writeln('       package opts: [--entry <label>] [--limit-steps <n>] [--limit-stack <n>] [--limit-call <n>]');
    writeln('       default output root: .cerberus_target (or CERBERUS_TARGET_DIR)');
    writeln('   or: compiler no-typecheck <input> [output]');
    writeln('   or: compiler package <vm_script> [output.crt] [package opts]');
    return;
  end;

  src_path := arg(arg_idx);
  pkg_entry := '';
  pkg_limit_steps := '';
  pkg_limit_stack := '';
  pkg_limit_call := '';
  if package_mode then
  begin
    if arg_count() > arg_idx + 1 then
    begin
      if starts_with(arg(arg_idx + 1), '--') then
      begin
        out_path := c_default_output_for(src_path, true);
        pkg_idx := arg_idx + 1;
      end
      else
      begin
        out_path := arg(arg_idx + 1);
        pkg_idx := arg_idx + 2;
      end;
    end
    else
    begin
      out_path := c_default_output_for(src_path, true);
      pkg_idx := arg_idx + 1;
    end;
    while pkg_idx < arg_count() do
    begin
      pkg_opt := arg(pkg_idx);
      if pkg_opt = '--entry' then
      begin
        if pkg_idx + 1 >= arg_count() then
        begin
          writeln('ERROR: --entry requires value');
          return;
        end;
        pkg_entry := arg(pkg_idx + 1);
        pkg_idx := pkg_idx + 2;
      end
      else if pkg_opt = '--limit-steps' then
      begin
        if pkg_idx + 1 >= arg_count() then
        begin
          writeln('ERROR: --limit-steps requires value');
          return;
        end;
        pkg_limit_steps := arg(pkg_idx + 1);
        pkg_idx := pkg_idx + 2;
      end
      else if pkg_opt = '--limit-stack' then
      begin
        if pkg_idx + 1 >= arg_count() then
        begin
          writeln('ERROR: --limit-stack requires value');
          return;
        end;
        pkg_limit_stack := arg(pkg_idx + 1);
        pkg_idx := pkg_idx + 2;
      end
      else if pkg_opt = '--limit-call' then
      begin
        if pkg_idx + 1 >= arg_count() then
        begin
          writeln('ERROR: --limit-call requires value');
          return;
        end;
        pkg_limit_call := arg(pkg_idx + 1);
        pkg_idx := pkg_idx + 2;
      end
      else
      begin
        writeln(concat('ERROR: unknown package option ', pkg_opt));
        return;
      end;
    end;
  end
  else
  begin
    if arg_count() > arg_idx + 1 then
      out_path := arg(arg_idx + 1)
    else
      out_path := c_default_output_for(src_path, false);
    if arg_count() > arg_idx + 2 then
      writeln(concat('WARN: extra arguments ignored, count=', p_int_to_str(arg_count() - arg_idx - 2)));
  end;

  if env_has('CERBERUS_DEBUG_AST') then
    writeln(concat('DEBUG: src_path=', src_path));
  if env_has('CERBERUS_DEBUG_AST') then
    writeln(concat('DEBUG: out_path=', out_path));
  src := readfile(src_path);
  if env_has('CERBERUS_DEBUG_PROGRESS') then
    writeln('PROGRESS: readfile');
  if env_has('CERBERUS_DEBUG_AST') then
    writeln('DEBUG: readfile ok');
  if package_mode then
  begin
    err := vm_validate_script(src);
    if err <> '' then
    begin
      writeln(concat('ERROR: invalid vm script for package: ', err));
      return;
    end;
    src := vm_toolchain_pack(src, pkg_entry, pkg_limit_steps, pkg_limit_stack, pkg_limit_call);
    ast := vm_toolchain_resolve_strict(src);
    if starts_with(ast, 'ERROR:') then
    begin
      writeln(ast);
      return;
    end;
    err := vm_validate_script(ast);
    if err <> '' then
    begin
      writeln(concat('ERROR: packaged script invalid: ', err));
      return;
    end;
    writefile(out_path, src);
    c_write_build_meta('package', src_path, out_path);
    writeln(concat('ok: wrote package ', out_path));
    return;
  end;
  ast := parse_string(src);
  if env_has('CERBERUS_DEBUG_PROGRESS') then
    writeln('PROGRESS: parsed');
  if env_has('CERBERUS_DEBUG_AST') then
    writeln('DEBUG: parse_string ok');
  ast := c_merge_uses(ast, c_dirname(src_path));
  if env_has('CERBERUS_DEBUG_PROGRESS') then
    writeln('PROGRESS: merged');
  if env_has('CERBERUS_DEBUG_AST') then
    writeln('DEBUG: merge_uses ok');
  if env_has('CERBERUS_DEBUG_AST') then
  begin
    if strlen(ast) > 120 then
      writeln(concat('AST_HEAD: ', substr(ast, 0, 120)))
    else
      writeln(concat('AST_HEAD: ', ast));
  end;

  if starts_with(ast, 'ERROR:') then
  begin
    writeln(ast);
    return;
  end;
  if substr(ast, 0, 2) <> 'P{' then
  begin
    writeln(concat('ERROR: invalid ast: ', substr(ast, 0, 120)));
    return;
  end;

  if env_has('CERBERUS_DEBUG_AST') then
    writeln('DEBUG: typecheck start');
  if env_has('CERBERUS_DEBUG_AST') then
  begin
    if no_tc then
      writeln('DEBUG: no_tc=true')
    else
      writeln('DEBUG: no_tc=false');
  end;
  if not no_tc then
  begin
    if env_has('CERBERUS_DEBUG_PROGRESS') then
      writeln('PROGRESS: typecheck start');
    if not typecheck_ok(ast) then
    begin
      err := typecheck_error(ast);
      if err = '' then
        err := 'typecheck failed';
      writeln(concat('ERROR: ', err));
      return;
    end;
    if env_has('CERBERUS_DEBUG_PROGRESS') then
      writeln('PROGRESS: typecheck done');
  end;
  if env_has('CERBERUS_DEBUG_AST') then
  begin
    if no_tc then
      writeln('DEBUG: typecheck skipped')
    else
      writeln('DEBUG: typecheck ok');
  end;

  if env_has('CERBERUS_DEBUG_AST') then
    writeln('DEBUG: codegen start');
  if env_has('CERBERUS_DEBUG_PROGRESS') then
    writeln('PROGRESS: codegen start');
  codegen_emit_to(ast, out_path);
  c_write_build_meta('bytecode', src_path, out_path);
  if env_has('CERBERUS_DEBUG_PROGRESS') then
    writeln('PROGRESS: codegen done');
  if env_has('CERBERUS_DEBUG_AST') then
    writeln('DEBUG: codegen ok');
  writeln(concat('ok: wrote ', out_path));
end.
