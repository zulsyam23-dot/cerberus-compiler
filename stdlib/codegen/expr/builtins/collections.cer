program codegen_expr_builtins_collections_mod;
function cg_builtin_is_vector(name: string): boolean;
begin
  return name = 'vector_new' or name = 'vector_new_int' or name = 'vector_new_bool' or name = 'vector_new_str' or
         name = 'vector_len' or name = 'vector_get' or name = 'vector_set' or name = 'vector_push' or
         name = 'vector_remove' or name = 'vector_last' or name = 'vector_pop' or name = 'vector_clear';
end;
function cg_builtin_is_map(name: string): boolean;
begin
  return name = 'map_new' or name = 'map_len' or name = 'map_set' or name = 'map_get' or
         name = 'map_has' or name = 'map_remove' or name = 'map_clear';
end;
function cg_builtin_is_collection(name: string): boolean;
begin
  return cg_builtin_is_vector(name) or cg_builtin_is_map(name);
end;
begin
end.
