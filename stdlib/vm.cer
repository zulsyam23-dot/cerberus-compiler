program vm;
uses runtime_mod;

function vm_available(): boolean;
begin
  return rt_vm_runtime_available();
end;

function vm_execute_text(src: string): string;
begin
  return rt_vm_runtime_run_text(src);
end;

function vm_execute_file(path: string): string;
begin
  return rt_vm_runtime_run_file(path);
end;

function vm_execute_file_strict(path: string): string;
begin
  return rt_vm_runtime_run_file_strict(path);
end;

function vm_validate_script(src: string): string;
begin
  return rt_vm_runtime_validate(src);
end;

function vm_default_limit_steps(): integer;
begin
  return rt_vm_runtime_default_steps();
end;

function vm_toolchain_pack(script: string; entry: string; limit_steps: string; limit_stack: string; limit_call: string): string;
begin
  return rt_vm_runtime_toolchain_pack(script, entry, limit_steps, limit_stack, limit_call);
end;

function vm_toolchain_resolve(src: string): string;
begin
  return rt_vm_runtime_toolchain_resolve(src);
end;

function vm_toolchain_resolve_strict(src: string): string;
begin
  return rt_vm_runtime_toolchain_resolve_strict(src);
end;

function vm_toolchain_is_package(src: string): boolean;
begin
  return rt_vm_runtime_toolchain_is_package(src);
end;

function vm_self_test(): boolean;
begin
  return rt_vm_runtime_self_test();
end;
begin
end.
