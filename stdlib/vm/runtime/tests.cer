program vm_runtime_tests;
uses dispatch, validate, io, runtime_ops, toolchain;

function vm_rt_contains(hay: string; needle: string): boolean;
var i: integer;
n: integer;
m: integer;
begin
  n := strlen(hay);
  m := strlen(needle);
  if m = 0 then
    return true;
  if n < m then
    return false;
  i := 0;
  while i <= n - m do
  begin
    if substr(hay, i, m) = needle then
      return true;
    i := i + 1;
  end;
  return false;
end;

function vm_rt_expect_ok(src: string): boolean;
begin
  return runtime_exec_text(src) = '';
end;

function vm_rt_expect_error_has(src: string; needle: string): boolean;
var err: string;
begin
  err := runtime_exec_text(src);
  return err <> '' and vm_rt_contains(err, needle);
end;

function vm_runtime_test_validate_unknown_opcode(): boolean;
var err: string;
begin
  err := rt_validate_text('unknown_op');
  return err <> '' and vm_rt_contains(err, 'unknown opcode');
end;

function vm_runtime_test_limit_steps(): boolean;
var src: string;
begin
  src := '@limit_steps 2; nop; nop; nop; halt;';
  return vm_rt_expect_error_has(src, 'limit: step exceeded');
end;

function vm_runtime_test_basic_arith(): boolean;
var src: string;
begin
  src := 'const_int 4; const_int 5; add; halt;';
  return vm_rt_expect_ok(src);
end;

function vm_runtime_test_ops_classifier(): boolean;
begin
  return rt_op_is_control('jump') and
         rt_op_is_const('const_int') and
         rt_op_is_known('map_set') and
         rt_op_is_directive('@entry') and
         rt_dir_is_known('@limit_steps') and
         rt_dir_requires_arg('@entry') and
         rt_dir_requires_int_arg('@cerberus_vm') and
         not rt_op_is_known('unknown_op');
end;

function vm_runtime_test_path_helpers(): boolean;
var joined: string;
base: string;
name: string;
begin
  base := 'tmp';
  name := 'demo.txt';
  joined := rt_io_join(base, name);
  return rt_io_basename(joined) = name and rt_io_dirname(joined) = base;
end;

function vm_runtime_test_toolchain_pack_resolve(): boolean;
var script: string;
pkg: string;
resolved: string;
begin
  script := 'label main; const_int 4; const_int 5; add; println; halt;';
  pkg := rt_toolchain_pack_script(script, 'main', '100', '64', '16');
  if not rt_toolchain_is_package(pkg) then
    return false;
  if not vm_rt_contains(pkg, ';vm=1') then
    return false;
  if not vm_rt_contains(pkg, ';abi=1') then
    return false;
  if not vm_rt_contains(pkg, ';features=') then
    return false;
  if not vm_rt_contains(pkg, ';artifact=vm_package') then
    return false;
  if not vm_rt_contains(pkg, ';toolchain=cerberus_selfhost') then
    return false;
  if not vm_rt_contains(pkg, ';checksum=') then
    return false;
  resolved := rt_toolchain_resolve(pkg);
  if vm_rt_contains(resolved, 'ERROR: toolchain artifact:') then
    return false;
  return vm_rt_expect_ok(resolved);
end;

function vm_runtime_test_toolchain_bad_format(): boolean;
var pkg: string;
resolved: string;
begin
  pkg := concat(rt_toolchain_magic(), ';unknown_format::code::halt;');
  resolved := rt_toolchain_resolve(pkg);
  return vm_rt_contains(resolved, 'ERROR: toolchain artifact: unsupported format');
end;

function vm_runtime_test_toolchain_backward_compat(): boolean;
var pkg: string;
resolved: string;
begin
  pkg := concat(rt_toolchain_magic(), ';vm_text_script::code::halt;');
  resolved := rt_toolchain_resolve(pkg);
  if vm_rt_contains(resolved, 'ERROR: toolchain artifact:') then
    return false;
  return vm_rt_expect_ok(resolved);
end;

function vm_runtime_test_toolchain_bad_vm_version(): boolean;
var pkg: string;
resolved: string;
begin
  pkg := concat(rt_toolchain_magic(), ';vm_text_script;vm=2::code::halt;');
  resolved := rt_toolchain_resolve(pkg);
  return vm_rt_contains(resolved, 'ERROR: toolchain artifact: unsupported vm version');
end;

function vm_runtime_test_toolchain_bad_feature(): boolean;
var pkg: string;
resolved: string;
begin
  pkg := concat(rt_toolchain_magic(), ';vm_text_script;features=core,net::code::halt;');
  resolved := rt_toolchain_resolve(pkg);
  return vm_rt_contains(resolved, 'ERROR: toolchain artifact: unsupported features');
end;

function vm_runtime_test_toolchain_checksum_mismatch(): boolean;
var pkg: string;
resolved: string;
begin
  pkg := concat(rt_toolchain_magic(), ';vm_text_script;checksum=123::code::halt;');
  resolved := rt_toolchain_resolve(pkg);
  return vm_rt_contains(resolved, 'ERROR: toolchain artifact: checksum mismatch');
end;

function vm_runtime_test_toolchain_strict_requires_fields(): boolean;
var pkg: string;
resolved: string;
begin
  pkg := concat(rt_toolchain_magic(), ';vm_text_script::code::halt;');
  resolved := rt_toolchain_resolve_strict(pkg);
  return vm_rt_contains(resolved, 'ERROR: toolchain artifact: missing header field vm');
end;

function vm_runtime_test_toolchain_strict_ok(): boolean;
var pkg: string;
resolved: string;
begin
  pkg := rt_toolchain_pack_script('halt;', '', '', '', '');
  resolved := rt_toolchain_resolve_strict(pkg);
  if vm_rt_contains(resolved, 'ERROR: toolchain artifact:') then
    return false;
  return vm_rt_expect_ok(resolved);
end;

function vm_runtime_test_toolchain_bad_artifact(): boolean;
var pkg: string;
resolved: string;
begin
  pkg := concat(rt_toolchain_magic(), ';vm_text_script;vm=1;abi=1;features=core;artifact=legacy;toolchain=cerberus_selfhost;checksum=123::code::halt;');
  resolved := rt_toolchain_resolve(pkg);
  return vm_rt_contains(resolved, 'ERROR: toolchain artifact: unsupported artifact legacy');
end;

function vm_runtime_tests_available(): boolean;
begin
  return true;
end;

function vm_runtime_tests_run(): boolean;
begin
  if not vm_runtime_test_validate_unknown_opcode() then
    return false;
  if not vm_runtime_test_limit_steps() then
    return false;
  if not vm_runtime_test_basic_arith() then
    return false;
  if not vm_runtime_test_ops_classifier() then
    return false;
  if not vm_runtime_test_path_helpers() then
    return false;
  if not vm_runtime_test_toolchain_pack_resolve() then
    return false;
  if not vm_runtime_test_toolchain_bad_format() then
    return false;
  if not vm_runtime_test_toolchain_backward_compat() then
    return false;
  if not vm_runtime_test_toolchain_bad_vm_version() then
    return false;
  if not vm_runtime_test_toolchain_bad_feature() then
    return false;
  if not vm_runtime_test_toolchain_checksum_mismatch() then
    return false;
  if not vm_runtime_test_toolchain_strict_requires_fields() then
    return false;
  if not vm_runtime_test_toolchain_strict_ok() then
    return false;
  if not vm_runtime_test_toolchain_bad_artifact() then
    return false;
  return true;
end;

function vm_runtime_tests_report(): string;
begin
  if vm_runtime_tests_run() then
    return 'ok';
  return 'failed';
end;

begin
end.
